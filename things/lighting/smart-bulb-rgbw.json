{
  "dmed_version": "0.2.0",
  "instance_id": "lt000001",
  "name": "Hall Light",
  "description": "RGBW smart bulb with dimming and color control",
  "service_type": "iot_device",
  "transports": [{"type": "http", "url": "http://192.168.1.10:8080/mcp", "priority": 1}],
  "auth": {"type": "none"},
  "capabilities": {
    "tools": [
      {"name": "toggle", "description": "Toggle light on/off", "inputSchema": {"type": "object", "properties": {}}},
      {"name": "set_brightness", "description": "Set brightness level", "inputSchema": {"type": "object", "properties": {"level": {"type": "integer", "minimum": 0, "maximum": 100}}, "required": ["level"]}},
      {"name": "set_color", "description": "Set light color", "inputSchema": {"type": "object", "properties": {"color": {"type": "string", "description": "Hex (#FF0000) or name (warm_white, cool_white, red, blue)"}}, "required": ["color"]}},
      {"name": "set_color_temperature", "description": "Set color temperature in Kelvin", "inputSchema": {"type": "object", "properties": {"kelvin": {"type": "integer", "minimum": 2700, "maximum": 6500}}, "required": ["kelvin"]}},
      {"name": "get_status", "description": "Get current state (on/off, brightness, color)", "inputSchema": {"type": "object", "properties": {}}}
    ],
    "resources": [],
    "prompts": []
  },
  "metadata": {"location": "hall", "floor": "3", "zone": "Flat-B304", "model": "RGBW-E27", "wattage": 9},
  "tags": ["lighting", "dimmable", "color", "smart-home"]
}
