      {"name": "set_motion_detection", "description": "Enable/disable motion alerts", "inputSchema": {"type": "object", "properties": {"enabled": {"type": "boolean"}, "sensitivity": {"type": "string", "enum": ["low", "medium", "high"]}}, "required": ["enabled"]}},
      {"name": "get_status", "description": "Get camera state, recording status, storage remaining", "inputSchema": {"type": "object", "properties": {}}}
    ],
    "resources": [],
    "prompts": []
  },
  "metadata": {"location": "hallway", "floor": "3", "zone": "Flat-B304", "model": "IndoorCam-2K", "resolution": "2K", "storage_gb": 64},
  "tags": ["camera", "security", "motion-detection", "smart-home"]
}
