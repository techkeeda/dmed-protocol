{
  "dmed_version": "0.2.0",
  "instance_id": "sc000002",
  "name": "Hallway Camera",
  "description": "Indoor security camera with motion detection and two-way audio",
  "service_type": "security",
  "transports": [{"type": "http", "url": "http://192.168.1.51:8080/mcp", "priority": 1}],
  "auth": {"type": "pin", "pin_mechanism": "companion_app"},
