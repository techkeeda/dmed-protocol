      {"name": "get_status", "description": "Get lock state and battery level", "inputSchema": {"type": "object", "properties": {}}},
      {"name": "get_access_log", "description": "Get recent access events", "inputSchema": {"type": "object", "properties": {"count": {"type": "integer", "minimum": 1, "maximum": 50}}}},
      {"name": "set_auto_lock", "description": "Enable auto-lock after N seconds", "inputSchema": {"type": "object", "properties": {"enabled": {"type": "boolean"}, "delay_seconds": {"type": "integer", "minimum": 5, "maximum": 300}}, "required": ["enabled"]}}
    ],
    "resources": [],
    "prompts": []
