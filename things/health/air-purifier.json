      {"name": "get_filter_life", "description": "Get remaining filter life percentage", "inputSchema": {"type": "object", "properties": {}}},
      {"name": "get_status", "description": "Get power state, mode, fan speed, AQI", "inputSchema": {"type": "object", "properties": {}}}
    ],
    "resources": [],
    "prompts": []
